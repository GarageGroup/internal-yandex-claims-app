{
  "version": "2.0",
  "extensions": {
    "http": {
      "routePrefix": ""
    }
  },
  "aggregator": {
    "batchSize": 1,
    "flushTimeout": "00:00:01"
  },
  "logging": {
    "logLevel": {
      "Host.Results": "Information",
      "Host.Aggregator": "Information",
      "Function.CreateWebSiteLead": "Information",
      "Function.CreateMetaLead": "Information"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond": 20,
        "excludedTypes": "Request;Exception"
      }
    }
  }
}